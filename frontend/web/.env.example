# ─── AWS Credentials ───────────────────────────────────────────────────────
# For local dev, provide explicit credentials.
# On Vercel / ECS, use IAM roles and omit these (the SDK resolves the role).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=           # Only needed for STS-assumed roles
AWS_REGION=us-east-1         # Must match the region where your Knowledge Base lives

# ─── Bedrock Knowledge Base ─────────────────────────────────────────────────
# Found in the AWS Console under Amazon Bedrock → Knowledge bases.
# Format: alphanumeric, e.g. "ABCDE12345"
BEDROCK_KNOWLEDGE_BASE_ID=

# Full model ARN for the generation step.
# Format: arn:aws:bedrock:{region}::foundation-model/{modelId}
# Example (Claude 3.5 Haiku in us-east-1):
#   arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-5-haiku-20241022-v1:0
# Example (Claude 3 Sonnet in us-east-1):
#   arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MODEL_ARN=

# ─── Python Librarian FastAPI ────────────────────────────────────────────────
# URL of the running FastAPI server (from src/librarian/tools/api/).
# Local: http://localhost:8000
# Docker / ECS ALB: https://your-alb-dns.region.elb.amazonaws.com
# Lambda Function URL: https://xxx.lambda-url.region.on.aws
LIBRARIAN_API_URL=http://localhost:8000
