{
  "eval_set_id": "receptionist_agent_evalset",
  "name": "Receptionist Agent — Independent Eval",
  "description": "Evaluates receptionist_agent in isolation, without going through the router.\n\nreceptionist_agent uses get_conversation_context (no args) and signal_follow_up (no args),\nboth of which are fully predictable — so tool_trajectory_avg_score can reliably assert them.\n\nCases:\n  greeting          — friendly opener: agent should check context and respond helpfully.\n  capabilities      — user asks what the system can help with: response should describe scope.\n  invoice_intent    — user expresses intent to see an invoice: agent should note the intent\n                      and use signal_follow_up to hand back control after asking for the ID.\n  out_of_scope_oos  — user asks something fully outside the product domain: agent should\n                      politely decline without inventing capabilities.",
  "eval_cases": [
    {
      "eval_id": "greeting",
      "conversation": [
        {
          "invocation_id": "inv_1",
          "user_content": { "parts": [{ "text": "Hi there!" }] },
          "final_response": {
            "role": "model",
            "parts": [{ "text": "" }]
          },
          "intermediate_data": {
            "tool_uses": [
              { "name": "get_conversation_context", "args": {} }
            ],
            "intermediate_responses": []
          }
        }
      ],
      "session_input": {
        "app_name": "receptionist_agent",
        "user_id": "eval_user",
        "state": {}
