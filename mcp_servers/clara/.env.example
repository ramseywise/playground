# Required: sevdesk API token — Settings → Integrations in sevdesk
SEVDESK_API_TOKEN=your-api-token-here

# MCP server transport (default: stdio for Claude Desktop / ADK)
MCP_HOST=127.0.0.1
MCP_PORT=8767

# Optional: Bedrock Knowledge Base for sevdesk support docs (fetch_support_knowledge tool)
BEDROCK_KNOWLEDGE_BASE_ID=
AWS_REGION=eu-central-1
# AWS_PROFILE=  # uncomment to use a named AWS profile instead of default credentials
