# Billy VA — environment variables
# Copy to .env and fill in required values

# --- LLM Provider ---
# Supported: gemini (default) | anthropic | openai
LLM_PROVIDER=gemini

# Required for LLM_PROVIDER=gemini (default)
GOOGLE_API_KEY=

# Optional model override (docker-compose only); defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Required for LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# Required for LLM_PROVIDER=openai
# OPENAI_API_KEY=

# --- Billy MCP Server ---
# BILLY_DB=billy.db
# MCP_HOST=127.0.0.1
# MCP_PORT=8765
# MCP_BASE_URL=http://127.0.0.1:8765

# --- Clara MCP Server ---
SEVDESK_API_TOKEN=

# --- VA Gateway ---
# GATEWAY_HOST=0.0.0.0
# GATEWAY_PORT=8000
# GATEWAY_BASE_URL=http://localhost:8000
# GATEWAY_API_KEY=

# --- Frontend ---
# FRONTEND_PORT=3000

# --- VA Agent (LangGraph) ---
# BILLY_MCP_URL=http://localhost:8765/sse
# LANGGRAPH_CHECKPOINTER=memory      # memory | postgres
# SESSION_TTL_SECONDS=1800           # Evict inactive in-memory sessions after N seconds (default: 30 min)
# SESSION_MAXSIZE=500                # Max concurrent sessions held in memory
# POSTGRES_URL=postgresql://va:va_dev@localhost:5432/va_checkpoints
# POSTGRES_PASSWORD=va_dev           # used by docker-compose
# MAX_HISTORY_TOKENS=12000
# MAX_MESSAGE_CHARS=4000
# ROUTING_CONFIDENCE_THRESHOLD=0.2

# --- AWS / Bedrock (support knowledge base) ---
# AWS_REGION=eu-central-1
# AWS_PROFILE=                       # leave blank to use default credential chain
# BEDROCK_KNOWLEDGE_BASE_ID=C36YGJVEQP

# --- Artefact storage ---
# ARTEFACT_BACKEND=local             # local | s3
# ARTEFACT_LOCAL_DIR=./artefacts
# ARTEFACT_S3_BUCKET=
# ARTEFACT_TTL_DAYS=30

# --- Memory ---
# MEMORY_DB_PATH=memory.db

# --- Safety ---
# CONFIRM_EXPENSIVE_OPS=0            # set to 1 to gate costly API calls

# --- Observability (optional) ---
# LANGFUSE_ENABLED=false
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# LangSmith (optional — https://smith.langchain.com/)
# export LANGSMITH_TRACING=true
# export LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# export LANGSMITH_API_KEY=
# export LANGSMITH_PROJECT=help-support-rag-agent
