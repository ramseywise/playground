# Librarian RAG Agent — environment variables
# Copy to .env and fill in required values

# --- Required ---
ANTHROPIC_API_KEY=

# --- Retrieval ---
RETRIEVAL_STRATEGY=chroma
RERANKER_STRATEGY=cross_encoder
CONFIDENCE_THRESHOLD=0.4
RETRIEVAL_K=10
RERANKER_TOP_K=3
PLANNING_MODE=rule_based

# --- Models ---
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# --- Storage ---
CHROMA_PERSIST_DIR=.chroma
DUCKDB_PATH=.duckdb/librarian.db

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Observability (optional) ---
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- OpenTelemetry (optional — requires: uv sync --extra otel) ---
# Set OTEL_ENABLED=true and run: docker compose --profile tracing up
OTEL_ENABLED=false
OTEL_EXPORTER=otlp        # otlp | phoenix
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=librarian

# --- OpenSearch (only if RETRIEVAL_STRATEGY=opensearch) ---
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=librarian-chunks
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=
