# LLM provider — gemini (default) | anthropic | openai
# Gemini: install base deps. Anthropic/OpenAI: uv sync --extra anthropic / --extra openai
LLM_PROVIDER=gemini
GOOGLE_API_KEY=

# Uncomment for alternate providers
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Data paths — three-store layout under playground/data/
# Point at playground/data/stores/ (shared with va-langgraph when Billy corpus is ready)
VECTORDB_PATH=../data/stores/vectordb/clara.duckdb
METADB_PATH=../data/stores/metadb/clara_meta.db
EVAL_DATASET_PATH=../data/eval_data/eval_v2.jsonl
RAW_DATA_DIR=../data/raw/clara_raw

# Embeddings (all-MiniLM-L6-v2 384-dim — must match the indexed clara.duckdb)
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_PROFILE=minilm
# Switch to multilingual-e5-large (1024-dim) only if re-indexing from scratch
# EMBEDDING_PROFILE=multilingual

# Vector store backend
VECTOR_STORE_BACKEND=duckdb
# VECTOR_STORE_BACKEND=opensearch
# OPENSEARCH_HOSTS=http://127.0.0.1:9200
# OPENSEARCH_INDEX=rag_chunks

# Checkpointer — sqlite for local dev, postgres for multi-worker / production
CHECKPOINTER_BACKEND=sqlite
# CHECKPOINTER_BACKEND=postgres
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/va_support_rag

# RAG pipeline tuning (defaults are production-safe for <2s latency)
# RAG_CONFIDENCE_THRESHOLD=0.25
# RAG_ENSEMBLE_SCORE_THRESHOLD=0.4
# RAG_ANSWER_CONTEXT_MAX_TOKENS=6000
# RAG_ENSEMBLE_TOP_K=8
# RAG_POLICY_MODE=scores_only     # hybrid adds LLM probe on borderline scores
# RAG_POST_ANSWER_EVALUATOR=false # keep false in prod — adds 300-700ms
# RAG_RETRIEVAL_QUERY_TRANSFORM=false
# RERANKER_BACKEND=passthrough    # cross_encoder adds ~150ms CPU; llm_listwise adds ~500ms
# RERANKER_TOP_K=5
# RAG_LLM_PLANNER=false

# Observability
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=va-support-rag
# LANGFUSE_HOST=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
