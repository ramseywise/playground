# Google / Gemini
GOOGLE_API_KEY=

# Optional: restrict API to clients that send X-API-Key header.
# Leave empty to disable auth (dev / local mode).
GATEWAY_API_KEY=

# Gateway bind address
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8001

# Gemini model
GEMINI_MODEL=gemini-2.5-flash-lite

# Billy MCP / REST (set automatically in docker-compose)
BILLY_MCP_URL=http://localhost:8765/sse
BILLY_API_URL=http://localhost:8766

# LangGraph checkpointer (memory | postgres)
LANGGRAPH_CHECKPOINTER=memory
POSTGRES_URL=
