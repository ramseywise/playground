# Google / Gemini
GOOGLE_API_KEY=

# Optional: restrict API to clients that send X-API-Key header.
# Leave empty to disable auth (dev / local mode).
GATEWAY_API_KEY=

# Gateway bind address
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Gemini model
GEMINI_MODEL=gemini-2.5-flash-lite

# Billy MCP / REST (set automatically in docker-compose)
BILLY_MCP_URL=http://localhost:8765/sse
BILLY_API_URL=http://localhost:8766

# LangSmith observability — set LANGSMITH_TRACING=true to enable
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=billy-va
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Langfuse (alternative — see observability.py for swap instructions)
# LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
